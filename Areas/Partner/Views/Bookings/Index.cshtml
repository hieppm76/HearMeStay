@model List<HearMeStay.Models.Booking>
@{ ViewData["Title"] = "Quản lý đặt phòng"; }
<div class="hms-table">
<table class="table">
    <thead><tr><th>Mã</th><th>Khách</th><th>Phòng</th><th>Check-in</th><th>Check-out</th><th>Tổng tiền</th><th>Trạng thái</th><th>Hành động</th></tr></thead>
    <tbody>
    @foreach(var b in Model){
        var statusText=b.BookingStatus switch{HearMeStay.Models.Enums.BookingStatus.Pending=>"Chờ xác nhận",HearMeStay.Models.Enums.BookingStatus.Confirmed=>"Đã xác nhận",HearMeStay.Models.Enums.BookingStatus.Rejected=>"Bị từ chối",HearMeStay.Models.Enums.BookingStatus.Cancelled=>"Đã hủy",HearMeStay.Models.Enums.BookingStatus.Completed=>"Đã hoàn tất",_=>""};
        var badgeCls=b.BookingStatus switch{HearMeStay.Models.Enums.BookingStatus.Pending=>"badge-pending",HearMeStay.Models.Enums.BookingStatus.Confirmed=>"badge-confirmed",HearMeStay.Models.Enums.BookingStatus.Rejected=>"badge-rejected",HearMeStay.Models.Enums.BookingStatus.Cancelled=>"badge-cancelled",HearMeStay.Models.Enums.BookingStatus.Completed=>"badge-completed",_=>""};
        <tr>
            <td><code style="color:var(--text-dark);">@b.BookingCode</code></td>
            <td>@b.User.FullName</td><td>@b.RoomType.Name</td>
            <td>@b.CheckInDate.ToString("dd/MM/yyyy")</td><td>@b.CheckOutDate.ToString("dd/MM/yyyy")</td>
            <td class="hms-price fw-bold">@b.TotalAmount.ToString("N0")₫</td>
            <td><span class="badge badge-status @badgeCls">@statusText</span></td>
            <td>
                <div class="d-flex gap-1">
                @if(b.BookingStatus==HearMeStay.Models.Enums.BookingStatus.Pending){<form asp-action="Confirm" asp-route-id="@b.Id" method="post" class="d-inline"><button class="btn btn-sm btn-success">Xác nhận</button></form><form asp-action="Reject" asp-route-id="@b.Id" method="post" class="d-inline"><button class="btn btn-sm btn-outline-danger">Từ chối</button></form>}
                @if(b.BookingStatus==HearMeStay.Models.Enums.BookingStatus.Confirmed){<form asp-action="MarkCompleted" asp-route-id="@b.Id" method="post" class="d-inline"><button class="btn btn-sm btn-primary">Hoàn tất</button></form>}
                <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary">Chi tiết</a>
                </div>
            </td>
        </tr>}
    </tbody>
</table>
</div>

@using Microsoft.AspNetCore.Identity
@using HearMeStay.Models
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Đối tác HearMeStay</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="hms-sidebar">
        <div class="sidebar-brand"><i class="bi bi-buildings"></i> HearMeStay</div>
        <div class="sidebar-label">Quản lý chính</div>
        <nav class="nav flex-column">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Dashboard"?"active":"")" asp-area="Partner" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i>Tổng quan</a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Accommodations"?"active":"")" asp-area="Partner" asp-controller="Accommodations" asp-action="MyAccommodation"><i class="bi bi-house"></i>Nơi lưu trú</a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Rooms"?"active":"")" asp-area="Partner" asp-controller="Rooms" asp-action="Index"><i class="bi bi-door-open"></i>Quản lý phòng</a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Bookings"?"active":"")" asp-area="Partner" asp-controller="Bookings" asp-action="Index"><i class="bi bi-calendar-check"></i>Booking</a>
        </nav>
        <div class="sidebar-label">AI & Insights</div>
        <nav class="nav flex-column">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="GuestInsights"?"active":"")" asp-area="Partner" asp-controller="GuestInsights" asp-action="Index"><i class="bi bi-lightbulb"></i>Guest Insight</a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="AddOnServices"?"active":"")" asp-area="Partner" asp-controller="AddOnServices" asp-action="Index"><i class="bi bi-plus-circle"></i>Dịch vụ cộng thêm</a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Reports"?"active":"")" asp-area="Partner" asp-controller="Reports" asp-action="Index"><i class="bi bi-graph-up"></i>Báo cáo</a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Packages"?"active":"")" asp-area="Partner" asp-controller="Packages" asp-action="Index"><i class="bi bi-box"></i>Gói dịch vụ</a>
        </nav>
        <hr style="border-color:var(--white-05);margin:.75rem 1.5rem;" />
        <nav class="nav flex-column">
            <a class="nav-link" asp-controller="Home" asp-action="Index" asp-area=""><i class="bi bi-arrow-left"></i>Về trang chủ</a>
        </nav>
        <div class="px-3 mt-2"><form asp-controller="Account" asp-action="Logout" asp-area="" method="post"><button type="submit" class="btn btn-sm w-100" style="background:var(--white-05);color:var(--white-50);border:1px solid var(--white-10);border-radius:var(--r);"><i class="bi bi-box-arrow-right me-1"></i>Đăng xuất</button></form></div>
    </div>
    <div class="hms-main-content">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3" style="border-bottom:1px solid var(--border-light);">
            <h4 class="fw-bold mb-0">@ViewData["Title"]</h4>
            <span class="text-muted small"><i class="bi bi-person-circle me-1"></i>@UserManager.GetUserAsync(User).Result?.FullName</span>
        </div>
        @if(TempData["Success"]!=null){<div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
        @if(TempData["Error"]!=null){<div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

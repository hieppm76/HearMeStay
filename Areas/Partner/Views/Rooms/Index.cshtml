@model List<HearMeStay.Models.RoomType>
@{ ViewData["Title"] = "Quản lý phòng"; }
<div class="d-flex justify-content-between mb-4"><h2 class="fw-bold">Quản lý phòng</h2><a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus"></i> Thêm loại phòng</a></div>
@foreach (var r in Model)
{
    <div class="card shadow-sm border-0 mb-3 p-3" style="border-radius:12px;">
        <div class="d-flex justify-content-between"><div><h5 class="fw-bold">@r.Name</h5><p class="text-muted mb-1">@r.PricePerNight.ToString("N0")₫/đêm | Sức chứa: @r.Capacity | Còn @r.AvailableRooms/@r.TotalRooms phòng</p></div>
        <div><a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary me-1">Sửa</a><form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa?');"><button class="btn btn-sm btn-outline-danger">Xóa</button></form></div></div>
    </div>
}

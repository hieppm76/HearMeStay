@model HearMeStay.Models.RoomType
@{ ViewData["Title"] = "Chỉnh sửa phòng"; }
<h2 class="fw-bold mb-4">Chỉnh sửa phòng</h2>
<div class="card shadow-sm border-0 p-4" style="border-radius:16px;">
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" /><input type="hidden" asp-for="AccommodationId" />
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="PricePerNight" class="form-label"></label><input asp-for="PricePerNight" class="form-control" type="number" /></div>
        <div class="col-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
        <div class="col-md-3"><label asp-for="Capacity" class="form-label"></label><input asp-for="Capacity" class="form-control" type="number" /></div>
        <div class="col-md-3"><label asp-for="TotalRooms" class="form-label"></label><input asp-for="TotalRooms" class="form-control" type="number" /></div>
        <div class="col-md-3"><label asp-for="AvailableRooms" class="form-label"></label><input asp-for="AvailableRooms" class="form-control" type="number" /></div>
        <div class="col-md-3"><label asp-for="BedType" class="form-label"></label><input asp-for="BedType" class="form-control" /></div>
    </div>
    <button type="submit" class="btn btn-primary mt-3">Lưu</button>
    <a asp-action="Index" class="btn btn-outline-secondary mt-3 ms-2">Hủy</a>
</form></div>

@{ ViewData["Title"] = "Bảng điều khiển quản trị"; }
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6"><div class="hms-stat"><div class="d-flex align-items-center gap-3"><div class="stat-icon" style="background:var(--teal-pale);color:var(--teal);"><i class="bi bi-people"></i></div><div><div class="stat-label">Tổng người dùng</div><div class="stat-value">@ViewBag.TotalUsers</div></div></div></div></div>
    <div class="col-xl-3 col-md-6"><div class="hms-stat"><div class="d-flex align-items-center gap-3"><div class="stat-icon" style="background:#D1FAE5;color:#065F46;"><i class="bi bi-building"></i></div><div><div class="stat-label">Tổng đối tác</div><div class="stat-value">@ViewBag.TotalPartners</div></div></div></div></div>
    <div class="col-xl-3 col-md-6"><div class="hms-stat"><div class="d-flex align-items-center gap-3"><div class="stat-icon" style="background:#DBEAFE;color:#1E40AF;"><i class="bi bi-house"></i></div><div><div class="stat-label">Nơi lưu trú</div><div class="stat-value">@ViewBag.TotalAccommodations</div></div></div></div></div>
    <div class="col-xl-3 col-md-6"><div class="hms-stat"><div class="d-flex align-items-center gap-3"><div class="stat-icon" style="background:#FEF3C7;color:#92400E;"><i class="bi bi-hourglass"></i></div><div><div class="stat-label">Chờ duyệt</div><div class="stat-value">@ViewBag.PendingAccommodations</div></div></div></div></div>
</div>
<div class="row g-3 mb-4">
    <div class="col-lg-4 col-md-6"><div class="hms-stat"><div class="stat-label mb-1"><i class="bi bi-calendar-check me-1" style="color:var(--teal);"></i>Tổng booking</div><div class="stat-value">@ViewBag.TotalBookings</div></div></div>
    <div class="col-lg-4 col-md-6"><div class="hms-stat"><div class="stat-label mb-1"><i class="bi bi-cash-coin me-1" style="color:var(--teal);"></i>Tổng hoa hồng</div><div class="stat-value hms-price">@(((decimal)ViewBag.TotalCommission).ToString("N0"))₫</div></div></div>
    <div class="col-lg-4 col-md-6"><div class="hms-stat"><div class="stat-label mb-1"><i class="bi bi-star-fill me-1 text-warning"></i>Đánh giá TB</div><div class="stat-value">@(((double)ViewBag.AvgRating).ToString("F1"))<span class="text-muted fs-6 fw-normal">/5</span></div></div></div>
</div>
@if(ViewBag.RecentBookings!=null){
    <div class="d-flex justify-content-between align-items-center mb-3"><h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2" style="color:var(--teal);"></i>Booking gần đây</h5><a asp-controller="Bookings" asp-action="Index" class="btn btn-outline-primary btn-sm">Xem tất cả</a></div>
    <div class="hms-table"><table class="table"><thead><tr><th>Mã</th><th>Khách</th><th>Nơi lưu trú</th><th>Tổng tiền</th><th>Ngày tạo</th></tr></thead><tbody>@foreach(HearMeStay.Models.Booking b in ViewBag.RecentBookings){<tr><td><code style="color:var(--text-dark);">@b.BookingCode</code></td><td>@b.User.FullName</td><td>@b.Accommodation.Name</td><td class="hms-price fw-bold">@b.TotalAmount.ToString("N0")₫</td><td class="text-muted">@b.CreatedAt.ToString("dd/MM/yyyy")</td></tr>}</tbody></table></div>
}

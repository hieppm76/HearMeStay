@{
    ViewData["Title"] = "Tìm phòng";
    var destination = ViewData["Destination"]?.ToString() ?? "Đà Nẵng";
}

<style>
    .search-page { padding-top: 70px; }
    .search-hero { background: var(--gradient); padding: 40px 5%; }
    .search-hero-box { background: white; border-radius: var(--radius); padding: 24px; box-shadow: 0 8px 32px rgba(0,0,0,0.15); }
    .search-hero-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr auto; gap: 12px; align-items: end; }
    .search-layout { display: grid; grid-template-columns: 280px 1fr; gap: 28px; padding: 32px 5%; }
    .results-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .results-count { font-size: 1rem; font-weight: 600; color: var(--navy); }
    .sort-select { padding: 8px 16px; border: 2px solid var(--gray-light); border-radius: 10px; font-size: 0.88rem; color: var(--navy); outline: none; font-family: 'Inter',sans-serif; }
    .result-card { display: grid; grid-template-columns: 280px 1fr; background: white; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); margin-bottom: 20px; transition: all 0.3s ease; }
    .result-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
    .result-img { width: 100%; height: 100%; min-height: 200px; object-fit: cover; }
    .result-body { padding: 22px; display: flex; flex-direction: column; }
    .result-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
    .result-title { font-size: 1.15rem; font-weight: 700; color: var(--navy); }
    .result-type { font-size: 0.75rem; font-weight: 600; color: var(--primary); background: var(--bg); padding: 3px 10px; border-radius: 50px; }
    .result-location { color: var(--gray); font-size: 0.85rem; margin-bottom: 10px; }
    .result-amenities { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
    .amenity-pill { background: var(--bg); color: var(--navy); font-size: 0.75rem; padding: 4px 10px; border-radius: 50px; }
    .result-match { background: #E0F7FA; border-left: 3px solid var(--secondary); padding: 8px 12px; border-radius: 0 8px 8px 0; font-size: 0.82rem; color: var(--primary); font-weight: 600; margin-bottom: 12px; }
    .result-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; }
    .result-price { font-size: 1.3rem; font-weight: 800; color: var(--primary); }
    .result-price span { font-size: 0.82rem; font-weight: 400; color: var(--gray); }
    .active-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
    .active-filter { background: var(--primary); color: white; font-size: 0.78rem; font-weight: 600; padding: 5px 14px; border-radius: 50px; display: flex; align-items: center; gap: 6px; }
    @@media(max-width:900px) { .search-layout { grid-template-columns: 1fr; } .result-card { grid-template-columns: 1fr; } .search-hero-grid { grid-template-columns: 1fr 1fr; } }
</style>

<div class="search-page">
    <div class="search-hero">
        <div class="search-hero-box">
            <form asp-controller="Hotel" asp-action="Search" method="get">
                <div class="search-hero-grid">
                    <div class="search-field"><label>📍 Điểm đến</label><input type="text" name="destination" value="@destination" placeholder="Hà Nội, Đà Nẵng, Phú Quốc..."/></div>
                    <div class="search-field"><label>📅 Check-in</label><input type="date" name="checkin"/></div>
                    <div class="search-field"><label>📅 Check-out</label><input type="date" name="checkout"/></div>
                    <div class="search-field"><label>👤 Khách</label><select name="guests"><option>1 khách</option><option selected>2 khách</option><option>3 khách</option><option>4+ khách</option></select></div>
                    <div class="search-field"><button type="submit" class="btn btn-primary" style="white-space:nowrap;border-radius:12px;padding:12px 24px;">🔍 Tìm</button></div>
                </div>
            </form>
        </div>
    </div>

    <div class="search-layout">
        <aside>
            <div class="filter-section">
                <div class="filter-title">🎛️ Bộ lọc</div>
                <div class="filter-group"><h4>Khoảng giá / đêm</h4><input type="range" class="range-slider" id="priceRange" min="200000" max="5000000" value="2000000" step="100000"/><div class="filter-range-val" id="priceDisplay">2.000.000 đ</div></div>
                <div class="filter-group"><h4>Loại hình lưu trú</h4>
                    <label class="filter-checkbox"><input type="checkbox" checked/> Khách sạn</label>
                    <label class="filter-checkbox"><input type="checkbox" checked/> Homestay</label>
                    <label class="filter-checkbox"><input type="checkbox"/> Villa</label>
                    <label class="filter-checkbox"><input type="checkbox"/> Resort</label>
                </div>
                <div class="filter-group" style="border-top:2px solid var(--primary);padding-top:20px;">
                    <h4 style="color:var(--primary);">🤖 Nhu cầu cá nhân</h4>
                    <label class="filter-checkbox"><input type="checkbox" checked/> 💑 Phù hợp cặp đôi</label>
                    <label class="filter-checkbox"><input type="checkbox"/> 👨‍👩‍👧 Gia đình có trẻ nhỏ</label>
                    <label class="filter-checkbox"><input type="checkbox"/> 🔇 Phòng yên tĩnh</label>
                    <label class="filter-checkbox"><input type="checkbox"/> 🥗 Hỗ trợ ăn chay</label>
                    <label class="filter-checkbox"><input type="checkbox"/> 🤧 Hỗ trợ người dị ứng</label>
                    <label class="filter-checkbox"><input type="checkbox"/> 🧘 Không gian chữa lành</label>
                    <label class="filter-checkbox"><input type="checkbox"/> 🎂 Setup sinh nhật</label>
                    <label class="filter-checkbox"><input type="checkbox"/> 🔥 Có BBQ</label>
                    <label class="filter-checkbox"><input type="checkbox"/> 💼 Phù hợp công tác</label>
                </div>
                <div class="filter-group"><h4>Tiện ích</h4>
                    <label class="filter-checkbox"><input type="checkbox" checked/> 🏊 Hồ bơi</label>
                    <label class="filter-checkbox"><input type="checkbox"/> 🏋️ Phòng gym</label>
                    <label class="filter-checkbox"><input type="checkbox"/> 💆 Spa</label>
                    <label class="filter-checkbox"><input type="checkbox" checked/> 📶 WiFi miễn phí</label>
                    <label class="filter-checkbox"><input type="checkbox"/> 🍳 Bữa sáng</label>
                </div>
                <button class="btn btn-primary" style="width:100%;justify-content:center;border-radius:12px;">Áp dụng bộ lọc</button>
            </div>
        </aside>

        <main>
            <div class="results-header">
                <div class="results-count">Tìm thấy <strong>48 chỗ lưu trú</strong> tại @destination</div>
                <select class="sort-select"><option>Phù hợp nhất</option><option>Giá thấp → cao</option><option>Giá cao → thấp</option><option>Đánh giá cao nhất</option></select>
            </div>
            <div class="active-filters">
                <span class="active-filter">💑 Cặp đôi <button>×</button></span>
                <span class="active-filter">🏊 Hồ bơi <button>×</button></span>
                <span class="active-filter">📶 WiFi <button>×</button></span>
            </div>

            <div class="result-card">
                <img class="result-img" src="https://images.unsplash.com/photo-1564501049412-61c2a3083791?w=500&q=80" alt="Fusion Maia"/>
                <div class="result-body">
                    <div class="result-top"><div><span class="result-type">Resort 5★</span><div class="result-title" style="margin-top:6px;">Fusion Maia Đà Nẵng</div></div><div class="rating"><span class="star">★</span> 4.9</div></div>
                    <div class="result-location">📍 Bãi biển Mỹ Khê, Sơn Trà, Đà Nẵng</div>
                    <div class="result-match">🤖 Phù hợp 92% với nhu cầu của bạn – Hỗ trợ phòng yên tĩnh cho cặp đôi, có spa và bữa sáng chay</div>
                    <div class="result-amenities"><span class="amenity-pill">🏊 Hồ bơi</span><span class="amenity-pill">💆 Spa</span><span class="amenity-pill">📶 WiFi</span><span class="amenity-pill">🍳 Bữa sáng</span></div>
                    <div class="result-footer"><div class="result-price">1.850.000 <span>đ/đêm</span></div><a asp-controller="Hotel" asp-action="Detail" asp-route-id="1" class="btn btn-primary">Xem chi tiết</a></div>
                </div>
            </div>

            <div class="result-card">
                <img class="result-img" src="https://images.unsplash.com/photo-1582719508461-905c673771fd?w=500&q=80" alt="Almanity"/>
                <div class="result-body">
                    <div class="result-top"><div><span class="result-type">Boutique 4★</span><div class="result-title" style="margin-top:6px;">Almanity Hội An Wellness Resort</div></div><div class="rating"><span class="star">★</span> 4.8</div></div>
                    <div class="result-location">📍 Hội An, Quảng Nam</div>
                    <div class="result-match">🤖 Phù hợp 88% – Chuyên nghỉ dưỡng, có menu chay, không dùng hóa chất mạnh</div>
                    <div class="result-amenities"><span class="amenity-pill">🧘 Yoga</span><span class="amenity-pill">💆 Spa</span><span class="amenity-pill">🥗 Menu chay</span><span class="amenity-pill">🏊 Hồ bơi</span></div>
                    <div class="result-footer"><div class="result-price">1.200.000 <span>đ/đêm</span></div><a asp-controller="Hotel" asp-action="Detail" asp-route-id="2" class="btn btn-primary">Xem chi tiết</a></div>
                </div>
            </div>

            <div class="result-card">
                <img class="result-img" src="https://images.unsplash.com/photo-1571003123894-1f0594d2b5d9?w=500&q=80" alt="Premier Village"/>
                <div class="result-body">
                    <div class="result-top"><div><span class="result-type">Resort 5★</span><div class="result-title" style="margin-top:6px;">Premier Village Danang Resort</div></div><div class="rating"><span class="star">★</span> 4.8</div></div>
                    <div class="result-location">📍 Bán đảo Sơn Trà, Đà Nẵng</div>
                    <div class="result-match">🤖 Phù hợp 85% – Pool villa lý tưởng cho cặp đôi, có setup kỷ niệm</div>
                    <div class="result-amenities"><span class="amenity-pill">🏊 Private pool</span><span class="amenity-pill">🍽️ Restaurant</span><span class="amenity-pill">🎂 Setup kỷ niệm</span></div>
                    <div class="result-footer"><div class="result-price">3.500.000 <span>đ/đêm</span></div><a asp-controller="Hotel" asp-action="Detail" asp-route-id="3" class="btn btn-primary">Xem chi tiết</a></div>
                </div>
            </div>

            <div class="result-card">
                <img class="result-img" src="https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=500&q=80" alt="Novotel"/>
                <div class="result-body">
                    <div class="result-top"><div><span class="result-type">Khách sạn 4★</span><div class="result-title" style="margin-top:6px;">Novotel Danang Premier Han River</div></div><div class="rating"><span class="star">★</span> 4.6</div></div>
                    <div class="result-location">📍 Trung tâm, Hải Châu, Đà Nẵng</div>
                    <div class="result-match">🤖 Phù hợp 78% – View sông Hàn, phù hợp công tác lẫn du lịch</div>
                    <div class="result-amenities"><span class="amenity-pill">🏊 Hồ bơi</span><span class="amenity-pill">🏋️ Gym</span><span class="amenity-pill">📶 WiFi</span><span class="amenity-pill">🅿️ Bãi xe</span></div>
                    <div class="result-footer"><div class="result-price">1.100.000 <span>đ/đêm</span></div><a asp-controller="Hotel" asp-action="Detail" asp-route-id="4" class="btn btn-primary">Xem chi tiết</a></div>
                </div>
            </div>
        </main>
    </div>
</div>

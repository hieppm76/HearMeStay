@{
    ViewData["Title"] = "Fusion Maia Đà Nẵng";
}

<style>
    .detail-page { padding-top: 70px; }
    .detail-content { padding: 36px 5%; max-width: 1280px; margin: 0 auto; }
    .detail-layout { display: grid; grid-template-columns: 1fr 360px; gap: 36px; }
    .hotel-name { font-size: 2rem; font-weight: 800; color: var(--navy); margin-bottom: 10px; }
    .hotel-meta { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
    .hotel-stars { color: #F59E0B; font-size: 1.1rem; letter-spacing: 2px; }
    .section-title { font-size: 1.15rem; font-weight: 700; color: var(--navy); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .detail-section { margin-bottom: 36px; }
    .amenities-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 10px; }
    .room-card { border: 2px solid var(--gray-light); border-radius: var(--radius-sm); overflow: hidden; margin-bottom: 16px; transition: border-color 0.2s; }
    .room-card:hover { border-color: var(--primary); }
    .room-card-body { padding: 16px; display: flex; justify-content: space-between; align-items: center; }
    .room-name { font-weight: 700; color: var(--navy); font-size: 0.95rem; }
    .room-size { font-size: 0.82rem; color: var(--gray); }
    .room-price { font-size: 1.1rem; font-weight: 800; color: var(--primary); text-align: right; }
    .room-price span { display: block; font-size: 0.75rem; font-weight: 400; color: var(--gray); }
    .review-item { border-bottom: 1px solid var(--gray-light); padding: 16px 0; }
    .review-item:last-child { border-bottom: none; }
    .review-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .review-author { font-weight: 600; color: var(--navy); font-size: 0.9rem; }
    .review-tag { font-size: 0.75rem; background: #E0F7FA; color: var(--primary); padding: 2px 10px; border-radius: 50px; display: inline-block; margin-bottom: 8px; }
    .review-text { font-size: 0.88rem; color: var(--gray); line-height: 1.7; }
    .sticky-book { background: white; border-radius: var(--radius); padding: 28px; box-shadow: var(--shadow); position: sticky; top: 90px; }
    .sticky-price { font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 20px; }
    .sticky-price span { font-size: 0.9rem; font-weight: 400; color: var(--gray); }
    .service-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--gray-light); }
    .service-name { font-size: 0.9rem; color: var(--navy); font-weight: 500; }
    .service-price { font-size: 0.88rem; font-weight: 700; color: var(--primary); }
    .service-badge { font-size: 0.72rem; background: #D1FAE5; color: #059669; padding: 2px 8px; border-radius: 50px; }
    @@media(max-width:900px){ .detail-layout { grid-template-columns: 1fr; } }
</style>

<div class="detail-page">
    <div class="detail-content">
        <div class="breadcrumb">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a><span>/</span>
            <a asp-controller="Hotel" asp-action="Search">Đà Nẵng</a><span>/</span>
            <span>Fusion Maia Đà Nẵng</span>
        </div>

        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:16px;margin-bottom:24px;">
            <div>
                <span class="card-tag" style="margin-bottom:8px;">Resort</span>
                <h1 class="hotel-name">Fusion Maia Đà Nẵng</h1>
                <div class="hotel-meta">
                    <span class="hotel-stars">★★★★★</span>
                    <div class="rating"><span class="star">★</span> 4.9 <span style="color:var(--gray);font-weight:400;">(312 đánh giá)</span></div>
                    <span style="color:var(--gray);font-size:0.88rem;">📍 Bãi biển Mỹ Khê, Sơn Trà, Đà Nẵng</span>
                </div>
            </div>
            <div class="match-score"><div class="match-pct">92%</div><div><div class="match-label">🤖 AI Match Score</div><div style="font-size:0.78rem;color:var(--gray);margin-top:2px;">Phù hợp với nhu cầu của bạn</div></div></div>
        </div>

        <div class="gallery" style="margin-bottom:36px;">
            <div class="gallery-main"><img src="https://images.unsplash.com/photo-1564501049412-61c2a3083791?w=800&q=80" alt="Main" style="width:100%;height:440px;object-fit:cover;"/></div>
            <img src="https://images.unsplash.com/photo-1582719508461-905c673771fd?w=400&q=80" alt="Pool"/>
            <img src="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=400&q=80" alt="Bedroom"/>
            <img src="https://images.unsplash.com/photo-1571003123894-1f0594d2b5d9?w=400&q=80" alt="Dining"/>
            <img src="https://images.unsplash.com/photo-1559592413-7cec4d0cae2b?w=400&q=80" alt="Spa"/>
        </div>

        <div class="detail-layout">
            <div>
                <div class="detail-section" style="background:linear-gradient(135deg,#E0F7FA,#F0F9FF);border-radius:var(--radius);padding:24px;border:1px solid var(--accent);">
                    <div class="section-title">🤖 Tại sao phù hợp với bạn?</div>
                    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px;">
                        <span class="tag tag-occasion">💑 Hỗ trợ cặp đôi/honeymoon</span>
                        <span class="tag tag-food">🥗 Có menu chay</span>
                        <span class="tag tag-room">🔇 Phòng yên tĩnh hướng biển</span>
                        <span class="tag tag-activity">💆 Spa cao cấp</span>
                        <span class="tag tag-upsell">🌹 Setup kỷ niệm theo yêu cầu</span>
                    </div>
                    <p style="font-size:0.88rem;color:var(--navy);line-height:1.7;">Fusion Maia có all-day spa included, phòng yên tĩnh nhìn ra biển và đội ngũ CSKH sẵn sàng chuẩn bị setup đặc biệt.</p>
                </div>

                <div class="detail-section">
                    <div class="section-title">📋 Giới thiệu</div>
                    <p style="color:var(--gray);line-height:1.85;font-size:0.93rem;">Fusion Maia Đà Nẵng là khu nghỉ dưỡng 5 sao nằm ngay bãi biển Mỹ Khê thơ mộng. Nổi tiếng với chính sách all-spa-included – khách được sử dụng spa không giới hạn trong suốt thời gian lưu trú. Với 97 phòng villa và suite đều có bồn tắm ngoài trời, hồ bơi riêng hoặc ban công view biển.</p>
                </div>

                <div class="detail-section">
                    <div class="section-title">✨ Tiện ích nổi bật</div>
                    <div class="amenities-grid">
                        <div class="amenity-item"><span class="amenity-icon">🏊</span> Hồ bơi vô cực</div>
                        <div class="amenity-item"><span class="amenity-icon">💆</span> Spa (miễn phí)</div>
                        <div class="amenity-item"><span class="amenity-icon">📶</span> WiFi tốc độ cao</div>
                        <div class="amenity-item"><span class="amenity-icon">🍳</span> Bữa sáng</div>
                        <div class="amenity-item"><span class="amenity-icon">🚗</span> Đưa đón sân bay</div>
                        <div class="amenity-item"><span class="amenity-icon">🧘</span> Yoga buổi sáng</div>
                        <div class="amenity-item"><span class="amenity-icon">🏋️</span> Phòng gym</div>
                        <div class="amenity-item"><span class="amenity-icon">🍽️</span> Nhà hàng</div>
                        <div class="amenity-item"><span class="amenity-icon">🏖️</span> Bãi biển riêng</div>
                        <div class="amenity-item"><span class="amenity-icon">🌡️</span> Điều hòa</div>
                        <div class="amenity-item"><span class="amenity-icon">📺</span> Smart TV</div>
                        <div class="amenity-item"><span class="amenity-icon">🧴</span> Amenities cao cấp</div>
                    </div>
                </div>

                <div class="detail-section">
                    <div class="section-title">🛏️ Các loại phòng</div>
                    <div class="room-card">
                        <img src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=700&q=80" alt="Garden Suite" style="width:100%;height:180px;object-fit:cover;"/>
                        <div class="room-card-body">
                            <div><div class="room-name">Garden Suite</div><div class="room-size">52m² · 1 giường King · Vườn riêng</div></div>
                            <div><div class="room-price">1.850.000 <span>đ/đêm</span></div><a asp-controller="Booking" asp-action="Create" asp-route-hotelId="1" class="btn btn-primary" style="margin-top:10px;font-size:0.85rem;padding:8px 18px;">Chọn phòng</a></div>
                        </div>
                    </div>
                    <div class="room-card">
                        <img src="https://images.unsplash.com/photo-1578683010236-d716f9a3f461?w=700&q=80" alt="Pool Villa" style="width:100%;height:180px;object-fit:cover;"/>
                        <div class="room-card-body">
                            <div><div class="room-name">Pool Villa</div><div class="room-size">85m² · 1 giường King · Hồ bơi riêng</div></div>
                            <div><div class="room-price">3.200.000 <span>đ/đêm</span></div><a asp-controller="Booking" asp-action="Create" asp-route-hotelId="1" class="btn btn-primary" style="margin-top:10px;font-size:0.85rem;padding:8px 18px;">Chọn phòng</a></div>
                        </div>
                    </div>
                </div>

                <div class="detail-section">
                    <div class="section-title">🎁 Dịch vụ cộng thêm</div>
                    <div class="service-item"><div><div class="service-name">🌹 Trang trí phòng lãng mạn</div><div style="font-size:0.78rem;color:var(--gray);">Hoa tươi, nến, rượu vang</div></div><div style="text-align:right;"><div class="service-price">850.000 đ</div><span class="service-badge">AI gợi ý</span></div></div>
                    <div class="service-item"><div><div class="service-name">🎂 Bánh sinh nhật/kỷ niệm</div><div style="font-size:0.78rem;color:var(--gray);">Tùy chỉnh theo yêu cầu</div></div><div style="text-align:right;"><div class="service-price">500.000 đ</div><span class="service-badge">AI gợi ý</span></div></div>
                    <div class="service-item"><div><div class="service-name">🚗 Đưa đón sân bay</div><div style="font-size:0.78rem;color:var(--gray);">Xe riêng, 2 chiều</div></div><div style="text-align:right;"><div class="service-price">400.000 đ</div></div></div>
                    <div class="service-item"><div><div class="service-name">🍽️ Private dinner bãi biển</div><div style="font-size:0.78rem;color:var(--gray);">Set 4 món, 2 người</div></div><div style="text-align:right;"><div class="service-price">1.500.000 đ</div></div></div>
                </div>

                <div class="detail-section">
                    <div class="section-title">⭐ Đánh giá từ khách</div>
                    <div class="review-item">
                        <div class="review-header"><div><span class="review-tag">💑 Cặp đôi</span><div class="review-author">Ngọc &amp; Minh · TP.HCM</div></div><div><span style="color:#F59E0B;">★★★★★</span></div></div>
                        <p class="review-text">Tuyệt vời! Tụi mình đi kỷ niệm, điền preference form và khi vào phòng đã có hoa, bánh và card chúc mừng. HearMeStay + Fusion Maia là combo hoàn hảo!</p>
                    </div>
                    <div class="review-item">
                        <div class="review-header"><div><span class="review-tag">🥗 Ăn chay</span><div class="review-author">Lan Anh · Hà Nội</div></div><div><span style="color:#F59E0B;">★★★★★</span></div></div>
                        <p class="review-text">Mình ăn chay và điền thông tin qua form. Bữa sáng buffet có riêng khu vực chay rất phong phú. Ấn tượng cực kỳ!</p>
                    </div>
                </div>
            </div>

            <div>
                <div class="sticky-book">
                    <div class="sticky-price">1.850.000 <span>đ/đêm</span></div>
                    <div class="form-group"><label>📅 Check-in</label><input type="date"/></div>
                    <div class="form-group"><label>📅 Check-out</label><input type="date"/></div>
                    <div class="form-group"><label>🛏️ Loại phòng</label><select><option>Garden Suite – 1.850.000 đ</option><option>Pool Villa – 3.200.000 đ</option></select></div>
                    <div class="form-group"><label>👤 Số khách</label><select><option>1 khách</option><option selected>2 khách</option></select></div>
                    <div style="background:var(--bg);border-radius:var(--radius-sm);padding:16px;margin-bottom:20px;">
                        <div class="summary-item"><span>3 đêm × 1.850.000 đ</span><span>5.550.000 đ</span></div>
                        <div class="summary-item"><span>Phí dịch vụ</span><span>277.500 đ</span></div>
                        <div class="summary-total"><span>Tổng cộng</span><span>5.827.500 đ</span></div>
                    </div>
                    <a asp-controller="Booking" asp-action="Create" asp-route-hotelId="1" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;border-radius:12px;margin-bottom:12px;">Đặt phòng ngay →</a>
                    <p style="font-size:0.78rem;color:var(--gray);text-align:center;">Sau khi đặt, bạn sẽ điền AI Preference Form.</p>
                    <div style="border-top:1px solid var(--gray-light);margin-top:20px;padding-top:16px;"><div style="font-size:0.82rem;color:var(--gray);line-height:1.7;">✅ Miễn phí hủy trước 24h<br/>✅ Xác nhận ngay lập tức<br/>✅ Không phí ẩn</div></div>
                </div>
            </div>
        </div>
    </div>
</div>

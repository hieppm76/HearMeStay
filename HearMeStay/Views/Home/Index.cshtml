                <span class="popular-tag">🔥 Hot</span>
            </div>
            <div class="card-body">
                <span class="card-tag">Resort</span>
                <div class="card-title">Fusion Maia Đà Nẵng</div>
                <div class="card-location">📍 Bãi biển Mỹ Khê, Đà Nẵng</div>
                <div class="card-footer">
                    <div class="card-price">1.850.000 <span>đ/đêm</span></div>
                    <div class="rating"><span class="star">★</span> 4.9 (312)</div>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-img-wrap">
                <img class="card-img" src="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=500&q=80" alt="Phú Quốc"/>
                <span class="popular-tag">🌊 Biển đẹp</span>
            </div>
            <div class="card-body">
                <span class="card-tag">Villa</span>
                <div class="card-title">Ocean Villa Phú Quốc</div>
                <div class="card-location">📍 Bãi Trường, Phú Quốc</div>
                <div class="card-footer">
                    <div class="card-price">2.400.000 <span>đ/đêm</span></div>
                    <div class="rating"><span class="star">★</span> 4.8 (189)</div>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-img-wrap">
                <img class="card-img" src="https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=500&q=80" alt="Hội An"/>
                <span class="popular-tag">🏆 Top rated</span>
            </div>
            <div class="card-body">
                <span class="card-tag">Boutique Hotel</span>
                <div class="card-title">La Siesta Hội An</div>
                <div class="card-location">📍 Phố cổ Hội An, Quảng Nam</div>
                <div class="card-footer">
                    <div class="card-price">980.000 <span>đ/đêm</span></div>
                    <div class="rating"><span class="star">★</span> 4.9 (427)</div>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-img-wrap">
                <img class="card-img" src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=500&q=80" alt="Hà Nội"/>
            </div>
            <div class="card-body">
                <span class="card-tag">Khách sạn 5★</span>
                <div class="card-title">Sofitel Legend Metropole</div>
                <div class="card-location">📍 Hoàn Kiếm, Hà Nội</div>
                <div class="card-footer">
                    <div class="card-price">4.200.000 <span>đ/đêm</span></div>
                    <div class="rating"><span class="star">★</span> 4.9 (856)</div>
                </div>
            </div>
        </div>
    </div>
    <div style="text-align:center;margin-top:40px;">
        <a asp-controller="Hotel" asp-action="Search" class="btn btn-primary btn-lg">Xem tất cả khách sạn →</a>
    </div>
</section>

<!-- AI PREFERENCE HIGHLIGHT -->
<section class="section bg-light" style="padding:80px 5%;">
    <div class="grid-2" style="align-items:center;gap:60px;">
        <div>
            <div class="section-label">Tính năng độc đáo</div>
            <h2 style="font-size:2rem;font-weight:800;color:var(--navy);margin-bottom:16px;">Chia sẻ nhu cầu –<br/><span class="text-gradient">Khách sạn chuẩn bị</span></h2>
            <p style="color:var(--gray);margin-bottom:28px;line-height:1.8;">Chỉ cần viết một câu, AI sẽ phân tích và gửi đúng thông tin đến đúng bộ phận. Bạn không cần nhắc lại khi đến nơi.</p>
            <div style="background:white;border-radius:var(--radius);padding:24px;box-shadow:var(--shadow);margin-bottom:28px;">
                <div style="font-size:0.82rem;color:var(--gray);margin-bottom:10px;">Khách nhập:</div>
                <div style="font-style:italic;color:var(--navy);font-size:0.95rem;margin-bottom:16px;">"Bạn gái mình dị ứng hải sản, tụi mình đi kỷ niệm 2 năm, muốn phòng yên tĩnh và không có mùi tinh dầu."</div>
                <div style="font-size:0.82rem;color:var(--gray);margin-bottom:10px;">AI tạo tags:</div>
                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                    <span class="tag tag-allergy">🦐 Dị ứng hải sản</span>
                    <span class="tag tag-occasion">💑 Kỷ niệm 2 năm</span>
                    <span class="tag tag-room">🔇 Phòng yên tĩnh</span>
                    <span class="tag tag-room">🌿 Không tinh dầu</span>
                    <span class="tag tag-upsell">💐 Gợi ý trang trí</span>
                </div>
            </div>
            <a asp-controller="Preference" asp-action="Form" class="btn btn-primary">Thử ngay AI Preference Form →</a>
        </div>
        <div>
            <div style="background:var(--gradient);border-radius:var(--radius);padding:32px;color:white;">
                <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:20px;">📊 Dashboard khách sạn nhận được</h3>
                <div style="background:rgba(255,255,255,0.1);border-radius:var(--radius-sm);padding:16px;margin-bottom:12px;">
                    <div style="font-size:0.8rem;opacity:0.75;margin-bottom:6px;">Khách sắp đến</div>
                    <div style="font-weight:700;">Nguyễn Minh Anh</div>
                    <div style="font-size:0.82rem;opacity:0.8;">Check-in: 20/06/2026 · 2 khách</div>
                </div>
                <div style="margin-bottom:12px;">
                    <div style="font-size:0.8rem;opacity:0.75;margin-bottom:8px;">AI Tags:</div>
                    <div style="display:flex;flex-wrap:wrap;gap:6px;">
                        <span style="background:rgba(255,255,255,0.2);padding:4px 10px;border-radius:50px;font-size:0.75rem;">🦐 Seafood Allergy</span>
                        <span style="background:rgba(255,255,255,0.2);padding:4px 10px;border-radius:50px;font-size:0.75rem;">💑 Anniversary</span>
                        <span style="background:rgba(255,255,255,0.2);padding:4px 10px;border-radius:50px;font-size:0.75rem;">🔇 Quiet Room</span>
                    </div>
                </div>
                <div>
                    <div style="font-size:0.8rem;opacity:0.75;margin-bottom:8px;">Việc cần chuẩn bị:</div>
                    <div style="display:flex;flex-direction:column;gap:6px;">
                        <div style="font-size:0.82rem;background:rgba(255,255,255,0.1);padding:8px 12px;border-radius:8px;">🍽️ Bếp: Tránh hải sản hoàn toàn</div>
                        <div style="font-size:0.82rem;background:rgba(255,255,255,0.1);padding:8px 12px;border-radius:8px;">🧹 Housekeeping: Không dùng tinh dầu</div>
                        <div style="font-size:0.82rem;background:rgba(255,255,255,0.1);padding:8px 12px;border-radius:8px;">💐 CSKH: Gợi ý gói trang trí kỷ niệm</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- TESTIMONIALS -->

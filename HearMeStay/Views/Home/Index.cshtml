@{
    ViewData["Title"] = "Understanding You Before You Arrive";
}

<style>
    .navbar.scrolled { box-shadow: 0 4px 20px rgba(0,119,182,0.15); }
    .hero-wave { position: absolute; bottom: -2px; left: 0; width: 100%; }
    .card-img-wrap { position: relative; }
    .popular-tag { position: absolute; top: 12px; left: 12px; background: white; color: var(--primary); font-size: 0.75rem; font-weight: 700; padding: 4px 12px; border-radius: 50px; }
    .how-section { background: var(--bg); }
    .partner-strip { background: white; padding: 40px 5%; text-align: center; border-bottom: 1px solid var(--gray-light); }
    .partner-strip p { color: var(--gray); font-size: 0.85rem; margin-bottom: 24px; font-weight: 500; }
    .partner-logos { display: flex; gap: 40px; align-items: center; justify-content: center; flex-wrap: wrap; }
    .partner-logo { font-size: 1.2rem; font-weight: 800; color: var(--gray-light); letter-spacing: -0.5px; transition: color 0.2s; }
    .partner-logo:hover { color: var(--primary); }
    .hero-tags { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-top: 20px; }
    .hero-tag { background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.9); padding: 6px 16px; border-radius: 50px; font-size: 0.8rem; }
</style>

<!-- HERO -->
<section class="hero">
    <div class="hero-content fade-in">
        <div class="hero-badge">✨ AI-Powered Personalization</div>
        <h1>Understanding You<br/><span>Before You Arrive</span></h1>
        <p>Không chỉ đặt phòng – HearMeStay giúp nơi lưu trú hiểu bạn trước khi bạn đến. Chia sẻ nhu cầu, AI phân tích, khách sạn chuẩn bị.</p>

        <div class="search-box">
            <form asp-controller="Hotel" asp-action="Search" method="get">
                <div class="search-grid">
                    <div class="search-field">
                        <label>📍 Điểm đến</label>
                        <input type="text" name="destination" placeholder="Hà Nội, Đà Nẵng, Phú Quốc..."/>
                    </div>
                    <div class="search-field">
                        <label>📅 Check-in</label>
                        <input type="date" name="checkin"/>
                    </div>
                    <div class="search-field">
                        <label>📅 Check-out</label>
                        <input type="date" name="checkout"/>
                    </div>
                    <div class="search-field">
                        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;border-radius:12px;">🔍 Tìm</button>
                    </div>
                </div>
            </form>
        </div>

        <div class="hero-tags">
            <span class="hero-tag">🥗 Ăn chay</span>
            <span class="hero-tag">💑 Kỷ niệm</span>
            <span class="hero-tag">👶 Gia đình</span>
            <span class="hero-tag">🤧 Dị ứng</span>
            <span class="hero-tag">💼 Công tác</span>
            <span class="hero-tag">🧘 Nghỉ dưỡng</span>
        </div>
    </div>
    <svg class="hero-wave" viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#F0F9FF"/>
    </svg>
</section>

<!-- PARTNER STRIP -->
<div class="partner-strip">
    <p>Hơn 500+ đối tác khách sạn tin tưởng</p>
    <div class="partner-logos">
        <span class="partner-logo">Vinpearl</span>
        <span class="partner-logo">Novotel</span>
        <span class="partner-logo">Mường Thanh</span>
        <span class="partner-logo">La Siesta</span>
        <span class="partner-logo">Fusion</span>
        <span class="partner-logo">Almanity</span>
    </div>
</div>

<!-- STATS -->
<div class="stats-bar">
    <div><div class="stat-num">500+</div><div class="stat-label">Đối tác khách sạn</div></div>
    <div><div class="stat-num">12K+</div><div class="stat-label">Lượt đặt phòng</div></div>
    <div><div class="stat-num">98%</div><div class="stat-label">Khách hài lòng</div></div>
    <div><div class="stat-num">45+</div><div class="stat-label">Tỉnh thành</div></div>
</div>

<!-- HOW IT WORKS -->
<section class="section how-section" id="how-it-works">
    <div class="section-center">
        <div class="section-label">Quy trình</div>
        <h2>Cách <span>HearMeStay</span> hoạt động</h2>
        <div class="divider"></div>
        <p class="subtitle">6 bước đơn giản – từ đặt phòng đến trải nghiệm cá nhân hóa hoàn hảo</p>
    </div>
    <div class="steps">
        <div class="step-card"><div class="step-num">🏨</div><h3>1. Hotel Onboarding</h3><p>Khách sạn đăng ký, cập nhật thông tin phòng, giá, tiện ích và các dịch vụ cộng thêm lên hệ thống.</p></div>
        <div class="step-card"><div class="step-num">🔍</div><h3>2. Smart Booking</h3><p>Người dùng tìm kiếm theo địa điểm, giá, tiện ích và đặc biệt là nhu cầu cá nhân. Đặt phòng chỉ vài bước.</p></div>
        <div class="step-card"><div class="step-num">📝</div><h3>3. AI Preference Collection</h3><p>Sau khi đặt phòng, khách điền sở thích cá nhân: dị ứng, chế độ ăn, mục đích chuyến đi, yêu cầu đặc biệt.</p></div>
        <div class="step-card"><div class="step-num">🤖</div><h3>4. AI Insight Processing</h3><p>AI phân tích thông tin và tạo action tags rõ ràng gửi đến từng bộ phận của khách sạn.</p></div>
        <div class="step-card"><div class="step-num">🛎️</div><h3>5. Hotel Preparation</h3><p>Khách sạn nhận dashboard và chuẩn bị phòng, món ăn, dịch vụ phù hợp trước khi khách check-in.</p></div>
        <div class="step-card"><div class="step-num">⭐</div><h3>6. Personalized Stay & Feedback</h3><p>Khách đến và cảm nhận sự khác biệt. Sau lưu trú, hệ thống thu thập feedback để cải thiện AI.</p></div>
    </div>
</section>

<!-- FEATURES -->
<section class="features-section" id="features">
    <div class="section-center" style="color:white;">
        <div class="ai-badge">🤖 Powered by AI</div>
        <h2 style="color:white;">Điểm khác biệt của <span style="color:var(--accent);">HearMeStay</span></h2>
        <div class="divider"></div>
        <p style="color:rgba(255,255,255,0.8);">Không chỉ đặt phòng – chúng tôi mang đến trải nghiệm được cá nhân hóa thực sự</p>
    </div>
    <div class="features-grid">
        <div class="feature-card"><div class="feature-icon">🧠</div><h3>AI phân tích nhu cầu</h3><p>AI đọc hiểu câu văn tự do, phân loại nhu cầu thành các tag như Allergy, Special Occasion, Room Preference...</p></div>
        <div class="feature-card"><div class="feature-icon">🎯</div><h3>AI Match Score</h3><p>Xem % phù hợp giữa khách sạn và nhu cầu của bạn. Tìm được nơi lưu trú đúng nhất.</p></div>
        <div class="feature-card"><div class="feature-icon">🔔</div><h3>Bộ lọc cá nhân hóa</h3><p>Lọc theo ăn chay, dị ứng, phù hợp cặp đôi, gia đình, người lớn tuổi, không gian chữa lành...</p></div>
        <div class="feature-card"><div class="feature-icon">📊</div><h3>Guest Insight Dashboard</h3><p>Khách sạn thấy rõ từng nhu cầu, từng bộ phận biết việc cần làm. Không còn hiểu nhầm.</p></div>
        <div class="feature-card"><div class="feature-icon">💎</div><h3>Gợi ý upsell thông minh</h3><p>AI gợi ý dịch vụ phù hợp: trang trí kỷ niệm, spa, private dinner, tour địa phương.</p></div>
        <div class="feature-card"><div class="feature-icon">🔒</div><h3>Bảo mật dữ liệu</h3><p>Thông tin cá nhân được mã hóa và chỉ chia sẻ với nơi lưu trú bạn đặt phòng.</p></div>
    </div>
</section>

<!-- POPULAR DESTINATIONS -->

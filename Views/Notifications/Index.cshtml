@model List<HearMeStay.Models.Notification>
@{ ViewData["Title"] = "Thông báo"; }
<div class="container py-5">
    <h2 class="fw-bold mb-4">Thông báo</h2>
    @if (!Model.Any())
    {
        <p class="text-muted">Không có thông báo nào.</p>
    }
    else
    {
        @foreach (var n in Model)
        {
            <div class="card mb-2 shadow-sm border-0 @(!n.IsRead ? "border-start border-primary border-3" : "")" style="border-radius:12px;">
                <div class="card-body d-flex justify-content-between align-items-center py-3">
                    <div>
                        <h6 class="fw-bold mb-1">@n.Title</h6>
                        <p class="mb-0 text-muted">@n.Message</p>
                        <small class="text-muted">@n.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    @if (!n.IsRead)
                    {
                        <form asp-action="MarkAsRead" asp-route-id="@n.Id" method="post">
                            <button type="submit" class="btn btn-sm btn-outline-primary">Đánh dấu đã đọc</button>
                        </form>
                    }
                </div>
            </div>
        }
    }
</div>

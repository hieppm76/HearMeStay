@model HearMeStay.ViewModels.GuestPreferenceCreateViewModel
@{ ViewData["Title"] = "Chia sẻ nhu cầu cá nhân"; }
<div style="padding-top:100px;"></div>
<div class="container py-4">
    <div class="text-center mb-4 fade-up">
        <div class="hms-step-icon mx-auto mb-3" style="width:60px;height:60px;background:linear-gradient(135deg,var(--teal),var(--teal-light));color:#fff;"><i class="bi bi-chat-heart" style="font-size:1.3rem;"></i></div>
        <h2 class="hms-section-title">Chia sẻ nhu cầu cá nhân của bạn</h2>
        <p class="hms-section-sub">Thông tin này giúp nơi lưu trú chuẩn bị tốt hơn trước khi bạn đến.</p>
        <p class="text-muted small">Đặt phòng <strong>#@Model.BookingCode</strong> — @Model.AccommodationName</p>
    </div>

    <form asp-action="Create" method="post" id="preferenceForm">
        <input type="hidden" asp-for="BookingId" />
        <input type="hidden" asp-for="RawText" id="finalRawText" />
        
        <div asp-validation-summary="All" class="text-danger mb-3 text-center"></div>

        <div class="row g-4 justify-content-center">
            <!-- Left Column: Preferences -->
            <div class="col-lg-7">
                <!-- 1. Ăn uống & dị ứng -->
                <div class="hms-form-section fade-up">
                    <div class="hms-form-section-header"><div class="hms-form-section-icon" style="background:#FEE2E2;color:#991B1B;">🍽️</div><h6 class="hms-form-section-title">Ăn uống & dị ứng</h6></div>
                    <div class="row g-2">
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox" type="checkbox" value="Tôi ăn chay" id="chkFood1"><label class="form-check-label" for="chkFood1">Tôi ăn chay</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox" type="checkbox" value="Tôi dị ứng hải sản" id="chkFood2"><label class="form-check-label" for="chkFood2">Tôi dị ứng hải sản</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox" type="checkbox" value="Tôi không ăn đồ cay" id="chkFood3"><label class="form-check-label" for="chkFood3">Tôi không ăn đồ cay</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox" type="checkbox" value="Tôi cần bữa sáng phù hợp" id="chkFood4"><label class="form-check-label" for="chkFood4">Tôi cần bữa sáng phù hợp</label></div></div>
                    </div>
                </div>

                <!-- 2. Thói quen phòng -->
                <div class="hms-form-section fade-up">
                    <div class="hms-form-section-header"><div class="hms-form-section-icon" style="background:#DBEAFE;color:#1E40AF;">🛏️</div><h6 class="hms-form-section-title">Thói quen phòng</h6></div>
                    <div class="row g-2">
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox" type="checkbox" value="Tôi muốn phòng yên tĩnh" id="chkRoom1"><label class="form-check-label" for="chkRoom1">Tôi muốn phòng yên tĩnh</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox" type="checkbox" value="Tôi không thích mùi hương mạnh" id="chkRoom2"><label class="form-check-label" for="chkRoom2">Tôi không thích mùi hương mạnh</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox" type="checkbox" value="Tôi muốn giường lớn" id="chkRoom3"><label class="form-check-label" for="chkRoom3">Tôi muốn giường lớn</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox" type="checkbox" value="Tôi muốn phòng có ánh sáng tự nhiên" id="chkRoom4"><label class="form-check-label" for="chkRoom4">Tôi muốn phòng có ánh sáng tự nhiên</label></div></div>
                    </div>
                </div>

                <!-- 3. Dịp đặc biệt -->
                <div class="hms-form-section fade-up">
                    <div class="hms-form-section-header"><div class="hms-form-section-icon" style="background:#FEF3C7;color:#92400E;">🎉</div><h6 class="hms-form-section-title">Dịp đặc biệt</h6></div>
                    <div class="row g-2">
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox fee-trigger" type="checkbox" value="Đi sinh nhật" id="chkOcc1"><label class="form-check-label" for="chkOcc1">Sinh nhật</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox fee-trigger" type="checkbox" value="Đi kỷ niệm" id="chkOcc2"><label class="form-check-label" for="chkOcc2">Kỷ niệm</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox fee-trigger" type="checkbox" value="Honeymoon" id="chkOcc3"><label class="form-check-label" for="chkOcc3">Honeymoon</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox" type="checkbox" value="Chuyến đi gia đình" id="chkOcc4"><label class="form-check-label" for="chkOcc4">Chuyến đi gia đình</label></div></div>
                    </div>
                </div>

                <!-- 4. Dịch vụ thêm -->
                <div class="hms-form-section fade-up">
                    <div class="hms-form-section-header"><div class="hms-form-section-icon" style="background:#CFFAFE;color:#155E75;">🎯</div><h6 class="hms-form-section-title">Dịch vụ thêm</h6></div>
                    <div class="row g-2">
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox fee-trigger" type="checkbox" value="Cần trang trí phòng" id="chkSvc1"><label class="form-check-label" for="chkSvc1">Trang trí phòng</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox fee-trigger" type="checkbox" value="Cần đưa đón sân bay" id="chkSvc2"><label class="form-check-label" for="chkSvc2">Đưa đón sân bay</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox fee-trigger" type="checkbox" value="Muốn ăn BBQ" id="chkSvc3"><label class="form-check-label" for="chkSvc3">BBQ</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox fee-trigger" type="checkbox" value="Cần Spa" id="chkSvc4"><label class="form-check-label" for="chkSvc4">Spa</label></div></div>
                        <div class="col-md-6"><div class="form-check"><input class="form-check-input pref-checkbox fee-trigger" type="checkbox" value="Muốn đi tour địa phương" id="chkSvc5"><label class="form-check-label" for="chkSvc5">Tour địa phương</label></div></div>
                    </div>
                    <div id="feeWarningAlert" class="alert alert-warning mt-3 mb-0 d-none" style="font-size: .85rem; background-color: #fff3cd; border-color: #ffe69c;">
                        <i class="bi bi-exclamation-triangle-fill me-2 text-warning"></i><strong>Lưu ý:</strong> Một số dịch vụ hoặc yêu cầu bạn vừa chọn có thể phát sinh thêm phụ phí. Nơi lưu trú sẽ kiểm tra và thông báo chính xác số tiền (nếu có).
                    </div>
                </div>

                <!-- 5. Ghi chú thêm -->
                <div class="hms-form-section fade-up">
                    <div class="hms-form-section-header"><div class="hms-form-section-icon" style="background:#F3E8FF;color:#6B21A8;">📝</div><h6 class="hms-form-section-title">Ghi chú thêm</h6></div>
                    <textarea id="freeText" class="form-control" rows="3" placeholder="Ví dụ: Mình ăn chay, không thích mùi tinh dầu, muốn phòng yên tĩnh và đi kỷ niệm 2 năm."></textarea>
                </div>
            </div>

            <!-- Right Column: Confirmations & Submit -->
            <div class="col-lg-4">
                <div class="sticky-top" style="top: 100px;">
                    
                    @if (Model.SavedProfile != null)
                    {
                        <div class="alert alert-success mb-4 fade-up shadow-sm border-0" id="savedProfileCard" style="background-color: #f0fdf4;">
                            <h6 class="alert-heading fw-bold mb-3"><i class="bi bi-person-hearts me-2 text-success"></i>Hồ sơ sở thích của bạn</h6>
                            <p class="mb-3 small text-muted">Chúng tôi tìm thấy hồ sơ của bạn từ các chuyến đi trước. Bạn có muốn dùng lại không?</p>
                            
                            <div class="d-grid gap-2 mb-3">
                                <button type="button" class="btn btn-success btn-sm" onclick="useSavedProfile()"><i class="bi bi-check2-circle me-1"></i> Dùng lại hồ sơ này</button>
                                <button type="button" class="btn btn-outline-success btn-sm" onclick="editSavedProfile()"><i class="bi bi-pencil me-1"></i> Chỉnh sửa trước khi gửi</button>
                            </div>
                            <div class="text-center">
                                <button type="button" class="btn btn-link text-muted small text-decoration-none p-0" onclick="ignoreSavedProfile()"><i class="bi bi-x-circle me-1"></i> Không dùng cho chuyến này</button>
                            </div>

                            <input type="hidden" id="savedFoodPref" value="@Model.SavedProfile.FoodPreferences" />
                            <input type="hidden" id="savedRoomPref" value="@Model.SavedProfile.RoomPreferences" />
                            <input type="hidden" id="savedServicePref" value="@Model.SavedProfile.ServicePreferences" />
                            <input type="hidden" id="savedAllergy" value="@Model.SavedProfile.AllergyNotes" />
                        </div>
                    }

                    <div class="alert alert-info fade-up border-0 shadow-sm" style="font-size: .88rem; background-color: #eff6ff; color: #1e40af;">
                        <i class="bi bi-info-circle-fill me-2"></i>Đây là bước gửi yêu cầu và chia sẻ nhu cầu cá nhân đến nơi lưu trú. Booking chỉ được giữ và chuyển sang bước thanh toán sau khi nơi lưu trú xác nhận.
                    </div>

                    <div class="hms-form-section fade-up shadow-sm" style="background:var(--teal-pale);border-color:rgba(13,148,136,.2);">
                        <h6 class="fw-bold mb-3" style="color: var(--teal-deep);"><i class="bi bi-shield-check me-2"></i>Xác nhận & Bảo mật</h6>
                        <div class="form-check mb-3">
                            <input asp-for="ConsentToShareWithHotel" class="form-check-input" />
                            <label asp-for="ConsentToShareWithHotel" class="form-check-label fw-bold" style="font-size: 0.9rem;">Tôi đồng ý chia sẻ thông tin này với nơi lưu trú để họ chuẩn bị dịch vụ.</label>
                            <span asp-validation-for="ConsentToShareWithHotel" class="text-danger d-block small"></span>
                        </div>
                        <hr style="opacity: 0.15;" />
                        <div class="form-check mb-3">
                            <input asp-for="SaveToProfile" class="form-check-input" checked />
                            <label asp-for="SaveToProfile" class="form-check-label" style="font-size: 0.9rem;">Lưu vào <a href="/PreferencesProfile/MyProfile" target="_blank" class="text-teal">Hồ sơ của tôi</a> cho các chuyến đi sau (tránh phải nhập lại nhiều lần).</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="ConsentToStoreHealthNotes" class="form-check-input" />
                            <label asp-for="ConsentToStoreHealthNotes" class="form-check-label text-muted" style="font-size:0.85rem;">Tôi đồng ý lưu lại các Ghi chú y tế và Dị ứng sức khỏe vào hồ sơ lâu dài.</label>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4 fade-up">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm"><i class="bi bi-send me-2"></i>Gửi yêu cầu</button>
                        <a asp-controller="Bookings" asp-action="MyBookings" class="btn btn-outline-secondary">Bỏ qua bước này</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('preferenceForm').addEventListener('submit', function (e) {
            let combinedText = [];
            
            // Gather checkboxes
            document.querySelectorAll('.pref-checkbox:checked').forEach(cb => {
                combinedText.push(cb.value);
            });
            
            // Gather free text
            let freeText = document.getElementById('freeText').value.trim();
            if (freeText) {
                combinedText.push(freeText);
            }
            
            // Set to hidden RawText
            document.getElementById('finalRawText').value = combinedText.join('. ');
        });

        // Handle Saved Profile
        function fillSavedPreferences() {
            const foodPref = document.getElementById('savedFoodPref').value;
            const roomPref = document.getElementById('savedRoomPref').value;
            const servicePref = document.getElementById('savedServicePref').value;
            const allergyPref = document.getElementById('savedAllergy').value;
            
            document.querySelectorAll('.pref-checkbox').forEach(cb => {
                if (foodPref && foodPref.includes(cb.value)) cb.checked = true;
                if (roomPref && roomPref.includes(cb.value)) cb.checked = true;
                if (servicePref && servicePref.includes(cb.value)) cb.checked = true;
                if (allergyPref && allergyPref.includes(cb.value)) cb.checked = true;
            });
            
            // Trigger change event to show/hide fee warning
            document.querySelectorAll('.fee-trigger').forEach(cb => {
                cb.dispatchEvent(new Event('change'));
            });
        }

        function useSavedProfile() {
            fillSavedPreferences();
            
            // Auto-check the consent checkbox since they are explicitly reusing their profile for this booking
            document.getElementById('ConsentToShareWithHotel').checked = true;
            
            // Highlight card
            document.getElementById('savedProfileCard').className = "alert alert-success mb-4 fade-up border-2 border-success";
            
            // Auto submit
            var form = document.getElementById('preferenceForm');
            // Trigger submit event listener to populate raw text
            form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
            form.submit();
        }

        function editSavedProfile() {
            fillSavedPreferences();
            document.getElementById('savedProfileCard').style.display = 'none';
            document.getElementById('freeText').focus();
            
            // Check the consent checkbox as a convenience
            document.getElementById('ConsentToShareWithHotel').checked = true;
            
            // Optional: Scroll to the first section
            window.scrollTo({ top: 300, behavior: 'smooth' });
        }

        function ignoreSavedProfile() {
            document.getElementById('savedProfileCard').style.display = 'none';
        }

        // Show fee warning if extra services are selected
        const feeTriggers = document.querySelectorAll('.fee-trigger');
        const feeWarningAlert = document.getElementById('feeWarningAlert');
        
        feeTriggers.forEach(cb => {
            cb.addEventListener('change', function() {
                const anyChecked = Array.from(feeTriggers).some(t => t.checked);
                if (anyChecked) {
                    feeWarningAlert.classList.remove('d-none');
                } else {
                    feeWarningAlert.classList.add('d-none');
                }
            });
        });
    </script>
}

@model HearMeStay.Models.GuestPreference
@{ ViewData["Title"] = "Thông tin nhu cầu cá nhân"; }
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 p-4" style="border-radius:16px;">
                <h2 class="fw-bold mb-3"><i class="bi bi-check-circle text-success"></i> Đã gửi thông tin nhu cầu cá nhân</h2>
                <p class="text-muted">Đặt phòng #@Model.Booking.BookingCode — @Model.Booking.Accommodation.Name</p>
                @if (Model.GuestInsight != null)
                {
                    <div class="alert alert-success mt-3"><strong>Tóm tắt AI:</strong> @Model.GuestInsight.Summary</div>
                    @if (Model.GuestInsight.Tags.Any())
                    {
                        <h5 class="fw-bold mt-3">Thẻ nhu cầu</h5>
                        <div class="mb-3">
                            @foreach (var tag in Model.GuestInsight.Tags)
                            {
                                <span class="badge me-1 mb-1 p-2" style="background:rgba(13,148,136,0.1);color:var(--primary-teal);">@tag.TagName</span>
                            }
                        </div>
                    }
                }
                <p class="text-muted mt-3">Nơi lưu trú sẽ chuẩn bị dựa trên nhu cầu phù hợp của bạn.</p>
                <a asp-controller="Bookings" asp-action="MyBookings" class="btn btn-primary">Quay lại danh sách đặt phòng</a>
            </div>
        </div>
    </div>
</div>

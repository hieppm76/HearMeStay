@model HearMeStay.ViewModels.AccommodationSearchViewModel
@{ ViewData["Title"] = "Nơi lưu trú"; }

<div style="padding-top:100px;"></div>
<div class="container py-4">
    <div class="mb-4 fade-up"><h2 class="hms-section-title">Khám phá nơi lưu trú phù hợp với bạn</h2><p class="hms-section-sub mt-1">Tìm khách sạn, homestay, villa và resort theo nhu cầu cá nhân.</p></div>

    <div class="hms-form-section mb-4 fade-up">
        <form method="get">
            <div class="row g-3 align-items-end">
                <div class="col-lg-3 col-md-6"><label class="form-label">Điểm đến</label><input type="text" name="City" value="@Model.City" class="form-control" placeholder="Thành phố, tỉnh..." /></div>
                <div class="col-lg-2 col-md-3"><label class="form-label">Nhận phòng</label><input type="date" name="CheckIn" value="@Model.CheckIn?.ToString("yyyy-MM-dd")" class="form-control" /></div>
                <div class="col-lg-2 col-md-3"><label class="form-label">Trả phòng</label><input type="date" name="CheckOut" value="@Model.CheckOut?.ToString("yyyy-MM-dd")" class="form-control" /></div>
                <div class="col-lg-1 col-md-2"><label class="form-label">Khách</label><input type="number" name="Guests" value="@Model.Guests" class="form-control" min="1" /></div>
                <div class="col-lg-2 col-md-4"><label class="form-label">Loại hình</label><select name="AccommodationType" class="form-select"><option value="">Tất cả</option><option value="Hotel">Khách sạn</option><option value="Homestay">Homestay</option><option value="Villa">Villa</option><option value="Resort">Resort</option><option value="Apartment">Căn hộ</option></select></div>
                <div class="col-lg-2 col-md-2"><button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i>Tìm</button></div>
            </div>
            <div class="d-flex flex-wrap gap-3 mt-3 pt-3" style="border-top:1px solid var(--border-light);">
                <span class="text-muted small fw-semibold"><i class="bi bi-cpu me-1"></i>Bộ lọc AI:</span>
                <div class="form-check"><input type="checkbox" name="IsQuietRoom" value="true" class="form-check-input" @(Model.IsQuietRoom==true?"checked":"") id="fq" /><label class="form-check-label small" for="fq">🤫 Yên tĩnh</label></div>
                <div class="form-check"><input type="checkbox" name="SupportsVeganMeal" value="true" class="form-check-input" @(Model.SupportsVeganMeal==true?"checked":"") id="fv" /><label class="form-check-label small" for="fv">🌱 Ăn chay</label></div>
                <div class="form-check"><input type="checkbox" name="SupportsAllergyRequest" value="true" class="form-check-input" @(Model.SupportsAllergyRequest==true?"checked":"") id="fa" /><label class="form-check-label small" for="fa">🛡️ Dị ứng</label></div>
            </div>
        </form>
    </div>

    @if (Model.Results.Any())
    {
        <p class="text-muted small mb-3">Tìm thấy <strong>@Model.Results.Count</strong> nơi lưu trú</p>
        <div class="row g-4">
        @foreach (var acc in Model.Results)
        {
            <div class="col-lg-4 col-md-6 fade-up">
                <div class="hms-card h-100">
                    <div class="card-img-wrap"><img src="@acc.MainImageUrl" class="card-img-top" alt="@acc.Name" /></div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2"><h6 class="fw-bold mb-0" style="font-size:.95rem;">@acc.Name</h6>@if(acc.StarRating.HasValue){<span class="badge" style="background:#FEF3C7;color:#92400E;font-size:.68rem;"><i class="bi bi-star-fill"></i> @acc.StarRating</span>}</div>
                        <p class="text-muted small mb-2"><i class="bi bi-geo-alt"></i> @acc.City, @acc.Province</p>
                        <div class="mb-2">@if(acc.HasQuietRoom){<span class="badge hms-badge hms-badge-ai me-1">🤫 Yên tĩnh</span>}@if(acc.HasVeganMeal){<span class="badge hms-badge hms-badge-ai me-1">🌱 Chay</span>}@if(acc.HasAllergySupport){<span class="badge hms-badge hms-badge-ai me-1">🛡️ Dị ứng</span>}</div>
                        <div class="d-flex justify-content-between align-items-center"><div><span class="hms-price">@acc.MinPrice.ToString("N0")₫</span><span class="text-muted small">/đêm</span></div>@if(acc.ReviewCount>0){<span class="small"><i class="bi bi-star-fill text-warning"></i> @acc.AverageRating.ToString("F1")</span>}</div>
                    </div>
                    <div class="card-footer"><a asp-action="Details" asp-route-id="@acc.Id" class="btn btn-outline-primary btn-sm w-100">Xem chi tiết</a></div>
                </div>
            </div>
        }
        </div>
    }
    else
    {
        <div class="text-center py-5 fade-up"><div class="hms-step-icon mx-auto mb-3" style="width:72px;height:72px;"><i class="bi bi-search" style="font-size:1.6rem;"></i></div><h5 class="fw-bold text-muted">Không tìm thấy kết quả</h5><p class="text-muted small">Hãy thử thay đổi bộ lọc.</p></div>
    }
</div>
